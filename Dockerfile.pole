# Pole engine worker image — pole_runner.py only
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends gcc libc-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy only what the pole engine needs
COPY pole_engine.py pole_runner.py ./

RUN mkdir -p /var/data
VOLUME ["/var/data"]

CMD ["python3", "pole_runner.py"]
